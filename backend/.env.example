# ─── Harmoniq Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# App
APP_ENV=development
APP_NAME=Harmoniq
DEBUG=true

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/harmoniq?sslmode=require

# Clerk authentication
# Get these from your Clerk dashboard → API Keys
CLERK_JWKS_URL=https://your-clerk-app.clerk.accounts.dev/.well-known/jwks.json

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting (slowapi format: "N/period")
RATE_LIMIT_DEFAULT=100/minute

# MusicBrainz — required by MetaBrainz API terms
# Format: "AppName/Version (contact@example.com)"
MUSICBRAINZ_USER_AGENT=Harmoniq/0.1.0 (your-email@example.com)
