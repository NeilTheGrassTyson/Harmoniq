# ─── Harmoniq Backend — Environment Variables ────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env.

# App
APP_ENV=development
APP_NAME=Harmoniq
DEBUG=true

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:pass@host/db?ssl=require

# Clerk authentication
# Get these from your Clerk dashboard → API Keys
CLERK_JWKS_URL=https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json
# Clerk secret key — Dashboard → API Keys → Secret keys
CLERK_SECRET_KEY=sk_live_...
# Clerk webhook secret — Dashboard → Webhooks → Add endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# CORS — comma-separated list of allowed origins
# 127.0.0.1 is required for the Spotify OAuth flow (loopback redirect URI)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting (slowapi format: "N/period")
RATE_LIMIT_DEFAULT=100/minute

# MusicBrainz — required by MetaBrainz API terms
# Format: "AppName/Version (contact@example.com)"
MUSICBRAINZ_USER_AGENT=Harmoniq/0.1.0 (your@email.com)

# Cloudflare R2 (avatar storage)
# Provision: Cloudflare Dashboard → R2 → Create bucket → Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=harmoniq-avatars
# Public URL: enable public access on the bucket or use a custom domain
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Spotify (account linking + listening display) — see docs/setup.md §6b
# Create the app at https://developer.spotify.com/dashboard, register the
# redirect URI EXACTLY as below, and add your Spotify account email under
# User Management (dev-mode allowlist). Then fill in the two credentials.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/spotify-callback

# Fernet key encrypting stored Spotify refresh tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating/losing it orphans stored tokens — users just reconnect.
TOKEN_ENCRYPTION_KEY=
